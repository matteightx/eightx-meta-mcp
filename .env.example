# Meta long-lived access token. Generate one at:
# https://developers.facebook.com/tools/explorer
# Required scopes: ads_read, business_management, pages_read_engagement,
# instagram_basic, instagram_manage_insights, read_insights
META_ACCESS_TOKEN=

# Meta Graph API version (optional, defaults to v21.0)
META_API_VERSION=v21.0

# Port for HTTP transport (Railway sets this automatically)
PORT=3000
